@model AllTrails.Models.TripReport

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Trip Report</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TrailId" />
            <input type="hidden" asp-for="CreatedDate" />

            <h3>
                @Model.Trail.Name
            </h3>

            <div class="mb-3">
                <label asp-for="Rating" class="control-label"></label>
                <input asp-for="Rating" class="form-control" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            @* <div class="mb-3">
                <label asp-for="TrailId" class="control-label"></label>
                <select asp-for="TrailId" class="form-control" asp-items="ViewBag.TrailId"></select>
                <span asp-validation-for="TrailId" class="text-danger"></span>
            </div> *@
            <div class="mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
